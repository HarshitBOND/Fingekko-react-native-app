{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "enabledPlugins": {
    "expo@claude-plugins-official": true
  },

  "permissions": {
    "defaultMode": "acceptEdits",

    "allow": [
      "Bash(npm *)",
      "Bash(pnpm *)",
      "Bash(npx expo *)",
      "Bash(node *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "Bash(git checkout *)"
    ],

    "ask": [
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(rm *)",
      "Bash(del *)",
      "Bash(sudo *)"
    ],

    "deny": [
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  }
}